# production | prod | development | dev — at build time, picks default API base and docs URL (see ui/lib/api.ts via next.config.mjs).
# Production UI builds: APP_ENV=prod or docker build --build-arg APP_ENV=prod
APP_ENV=dev

# Optional overrides (otherwise APP_ENV selects https://api.chainsinventinsanity.lol vs http://localhost:8000).
# NEXT_PUBLIC_API_BASE=http://localhost:8000
# NEXT_PUBLIC_SWAGGER_UI_URL=http://localhost:8080

# Umami analytics (optional). Base URL of your Umami instance (no trailing slash) and website ID from the dashboard.
# Example cloud: NEXT_PUBLIC_UMAMI_URL=https://cloud.umami.is
# Example self-hosted: NEXT_PUBLIC_UMAMI_URL=https://analytics.example.com
NEXT_PUBLIC_UMAMI_URL=
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
