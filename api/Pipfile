[[source]]
url = "https://pypi.org/simple"
verify_ssl = true
name = "pypi"

[packages]
markovify = "*"
requests = ">=2.33.1"
urllib3 = ">=2.6.3"
python-dotenv = "*"
gunicorn = "*"
Unidecode = "*"
Flask = ">=3.1.0"
flask-cors = ">=6.0.0"
boto3 = "*"

[dev-packages]
pytest = "*"

[scripts]
test = "pytest"
start = "gunicorn app:app --bind=0.0.0.0 --reload -c gunicorn.conf.py"
start-daemon = "gunicorn app:app --bind=0.0.0.0 --daemon -c gunicorn.conf.py"

[requires]
python_version = "3.14"
