DEBUG_MODE="True"
APP_KEY="a1b2c3d4"

# production | prod | development | dev — picks default CORS allowlist when CORS_ORIGINS is unset (see app.py).
# dev: localhost Next.js + loopback any port. prod: https://chainsinventinsanity.lol and https://www.…
APP_ENV="dev"

# Optional override: comma-separated exact browser origins (scheme + host + port). When set, replaces APP_ENV CORS defaults.
# CORS_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"

PORT=8000
USE_LOCAL_WORDLISTS="False"
LOCAL_QUESTION_WORDLIST="/path/to/questions.txt"
LOCAL_ANSWER_WORDLIST="/path/to/answers.txt"
REMOTE_QUESTION_WORDLIST="https://ci2-assets.chainsinventinsanity.lol/questions.txt"
REMOTE_ANSWER_WORDLIST="https://ci2-assets.chainsinventinsanity.lol/answers.txt"

# Optional: mirror print-cache PDFs to S3 (see print_cache_s3.py)
# PRINT_CACHE_S3_ENABLED="False"
# PRINT_CACHE_S3_BUCKET=""
# PRINT_CACHE_S3_PREFIX="print-cache"
# AWS_REGION="us-east-1"
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_S3_ENDPOINT_URL=""
# PRINT_CACHE_S3_PUBLIC_BASE_URL=""
# PRINT_CACHE_S3_URL_EXPIRES="3600"
# PRINT_CACHE_S3_REQUIRE_UPLOAD="False"

# Optional: shared directory for uploads (default: <api>/print_cache). Set the same path on the API and print-cache-cleanup when using a volume.
# PRINT_CACHE_DIR="/app/print_cache"

# Print-cache cleanup companion (print_cache_cleanup.py): max age before PDFs are removed locally and in S3 (when S3 is enabled).
# PRINT_CACHE_MAX_AGE_HOURS="24"
# PRINT_CACHE_MAX_AGE_SECONDS=""  # if set, overrides hours
# PRINT_CACHE_CLEANUP_INTERVAL_SECONDS="3600"